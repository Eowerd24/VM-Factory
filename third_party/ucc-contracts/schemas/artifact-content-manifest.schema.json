{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucc.dev/schemas/artifact-content-manifest.schema.json",
  "title": "ucc.artifact-content-manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "artifact_id", "revision_id", "entries"],
  "properties": {
    "schema": {"const": "ucc.artifact-content-manifest"},
    "schema_version": {"type": "integer", "minimum": 1},
    "artifact_id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
    "revision_id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/relpath"},
          "size": {"type": "integer", "minimum": 0},
          "sha256": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/hash"},
          "executable": {"type": "boolean"},
          "media_type": {"type": "string"}
        }
      }
    }
  }
}
