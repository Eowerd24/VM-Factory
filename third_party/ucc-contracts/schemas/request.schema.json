{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucc.dev/schemas/request.schema.json",
  "title": "ucc.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "schema_version", "request_id", "operation_id", "correlation_id",
    "idempotency_key", "request_fingerprint", "requested_at", "requested_by",
    "operation_type", "payload"
  ],
  "properties": {
    "schema": {"const": "ucc.request"},
    "schema_version": {"type": "integer", "minimum": 1},
    "request_id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
    "operation_id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
    "correlation_id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
    "causation_id": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"}
      ]
    },
    "idempotency_key": {"type": "string", "minLength": 1},
    "request_fingerprint": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/hash"},
    "requested_at": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/timestamp"},
    "requested_by": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
    "operation_type": {"type": "string", "minLength": 1},
    "payload": {"type": "object"}
  }
}
