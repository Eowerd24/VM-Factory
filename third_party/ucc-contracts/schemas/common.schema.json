{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucc.dev/schemas/common.schema.json",
  "title": "UCC common primitives",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*_[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "Prefixed Crockford ULID (SPEC-001 E.3)."
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "sha256:<64 lowercase hex> (SPEC-001 E.4)."
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{1,9}Z$",
      "description": "UTC RFC3339 with fractional seconds (UCC-Remaining-Baseline 2)."
    },
    "relpath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {"not": {"pattern": "^/"}},
        {"not": {"pattern": "\\\\"}},
        {"not": {"pattern": "(^|/)\\.\\.(/|$)"}},
        {"not": {"pattern": "(^|/)\\.(/|$)"}},
        {"not": {"pattern": "//"}},
        {"not": {"pattern": "[\\u0000-\\u001f]"}}
      ],
      "description": "Relative POSIX path; no traversal/absolute/backslash/control (SPEC-001 E.4, F.5)."
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"type": "string"},
        "id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
        "content_hash": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/hash"}
      }
    },
    "canonicalHeader": {
      "type": "object",
      "required": ["schema", "schema_version", "id", "created_at", "created_by", "record_version"],
      "properties": {
        "schema": {"type": "string"},
        "schema_version": {"type": "integer", "minimum": 1},
        "id": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
        "created_at": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/timestamp"},
        "created_by": {"$ref": "https://ucc.dev/schemas/common.schema.json#/$defs/id"},
        "record_version": {"type": "integer", "minimum": 1}
      }
    }
  }
}
